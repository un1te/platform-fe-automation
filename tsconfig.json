{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "jsx": "react-jsx",
        "baseUrl": "./",
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "types": [
            "node"
        ],
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "resolveJsonModule": true,
        "skipLibCheck": true
    },
    "exclude": [
        "eslint.config.mts"
    ]
}
