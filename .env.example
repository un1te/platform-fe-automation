# Application URLs
BASE_URL = https://your-app-domain.com/
API_URL = https://api.your-app-domain.com/api/v1

# Test Credentials
USERNAME = testuser@example.com
PASSWORD = your_test_password_here

# Proxy Configuration (optional, for secure environments)
PROXY = "socks5://127.0.0.1:9999"

# TestRail Integration (optional)
TESTRAIL_URL = https://your-testrail-instance.io/
TESTRAIL_USERNAME = your_testrail_email@example.com
TESTRAIL_API_KEY = your_testrail_api_key_here
TESTRAIL_PROJECT_ID = 1
TESTRAIL_SUITE_ID = 1
TESTRAIL_PROJECT_NAME = "Your Project Name"

# Instructions:
# 1. Copy this file to .env file in the project root
# 2. Replace placeholder values with your actual configuration
# 3. Never commit .env file with real credentials to version control
# 4. Add .env to .gitignore (already configured in this project)
